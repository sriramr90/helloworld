# Copy to .env and fill in what you have. Everything is OPTIONAL —
# the build runs with whatever is present and skips the rest.
#
# Curation (recommended): without this, the build falls back to a local
# sentiment ranking instead of LLM editorial curation.
OPENROUTER_API_KEY=
# Any model slug from https://openrouter.ai/models (it can route to Claude,
# GPT, Llama, etc.). Defaults to openai/gpt-4o-mini if unset.
OPENROUTER_MODEL=

# News sources that need a free API key. Omit either one and that source
# is simply skipped. GDELT and the positive-news RSS feeds need no key.
GUARDIAN_API_KEY=
GNEWS_API_KEY=
